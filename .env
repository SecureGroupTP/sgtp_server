CHAT_PORT=250
VOICE_PORT=251

# ── Multi-transport (Discovery + per-transport ports) ────────────────────────
# Set *_DISCOVERY_PORT to enable discovery for that service.
# TCP is the raw SGTP transport (legacy compatible).

# Chat
CHAT_DISCOVERY_PORT=260
CHAT_TCP_PORT=250
CHAT_HTTP_PORT=8080
CHAT_WS_PORT=8090

# Voice
VOICE_DISCOVERY_PORT=261
VOICE_TCP_PORT=251
VOICE_HTTP_PORT=8081
VOICE_WS_PORT=8091

# TLS transports (currently disabled in code; must stay 0)
CHAT_TCP_TLS_PORT=0
CHAT_HTTP_TLS_PORT=0
CHAT_WS_TLS_PORT=0
VOICE_TCP_TLS_PORT=0
VOICE_HTTP_TLS_PORT=0
VOICE_WS_TLS_PORT=0

# Optional bind host inside container (empty = all interfaces)
BIND_HOST=

# HTTP transport tuning
HTTP_RECV_TIMEOUT=60s
HTTP_SEND_MAX_BYTES=16777216
HTTP_SESSION_BUFFER_BYTES=4194304
HTTP_SESSION_TTL=10m
HTTP_SESSION_CLEANUP=1m
