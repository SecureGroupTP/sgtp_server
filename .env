CHAT_PORT=250
VOICE_PORT=251

# ── Multi-transport (Discovery + per-transport ports) ────────────────────────
# Set *_DISCOVERY_PORT to enable discovery for that service.
# TCP is the raw SGTP transport (legacy compatible).

# Chat
CHAT_DISCOVERY_PORT=260
CHAT_TCP_PORT=250
CHAT_HTTP_PORT=8080
CHAT_WS_PORT=8090

# Voice
VOICE_DISCOVERY_PORT=261
VOICE_TCP_PORT=251
VOICE_HTTP_PORT=8081
VOICE_WS_PORT=8091

# TLS transports (set non-zero to enable TLS once certificates are provided)
CHAT_TCP_TLS_PORT=1
CHAT_HTTP_TLS_PORT=1
CHAT_WS_TLS_PORT=1
VOICE_TCP_TLS_PORT=1
VOICE_HTTP_TLS_PORT=1
VOICE_WS_TLS_PORT=1

# TLS certificate/key (leave empty to keep TLS disabled)
TLS_CERT_FILE=./certs/certificate.crt
TLS_KEY_FILE=./certs/certificate.key

# Optional bind host inside container (empty = all interfaces)
BIND_HOST=

# HTTP transport tuning
HTTP_RECV_TIMEOUT=60s
HTTP_SEND_MAX_BYTES=16777216
HTTP_SESSION_BUFFER_BYTES=4194304
HTTP_SESSION_TTL=10m
HTTP_SESSION_CLEANUP=1m
