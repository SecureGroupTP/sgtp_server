# Chat
CHAT_TCP_PORT=250
CHAT_HTTP_PORT=8080
CHAT_WS_PORT=8080

# TLS transports (set non-zero to enable TLS once certificates are provided)
CHAT_TCP_TLS_PORT=444
CHAT_HTTP_TLS_PORT=0
CHAT_WS_TLS_PORT=0

# Optional discovery overrides (advertised to clients, not local listen ports)
# Useful behind reverse proxy/NAT, e.g. advertise HTTPS/WSS as 443.
ADVERTISE_TCP_PORT=250
ADVERTISE_TCP_TLS_PORT=444
ADVERTISE_HTTP_PORT=80
ADVERTISE_HTTP_TLS_PORT=443
ADVERTISE_WS_PORT=80
ADVERTISE_WS_TLS_PORT=443

# Public reverse-proxy settings (nginx + certbot)
NGINX_SERVER_NAME=

# TLS certificate/key (mount ./certs into containers so TLS_* paths resolve inside)
TLS_CERT_FILE=/certs/certificate.crt
TLS_KEY_FILE=/certs/certificate.key

# Optional bind host inside container (empty = all interfaces)
BIND_HOST=

# HTTP transport tuning
HTTP_RECV_TIMEOUT=60s
HTTP_SEND_MAX_BYTES=16777216
HTTP_SESSION_BUFFER_BYTES=4194304
HTTP_SESSION_TTL=10m
HTTP_SESSION_CLEANUP=1m

# Admin control plane
ADMIN_JWT_SECRET=
ADMIN_ACCESS_TTL=15m
ADMIN_REFRESH_TTL=168h
ADMIN_BOOTSTRAP_FILE=/tmp/admin_bootstrap_credentials.txt
